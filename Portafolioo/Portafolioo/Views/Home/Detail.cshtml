@model Portafolioo.Models.Proyecto

<div class="container my-5">
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImagenURL" class="img-fluid rounded" alt="@Model.Titulo" />
        </div>
        <div class="col-md-6">
            <h1>@Model.Titulo</h1>
            <p>@Model.Descripcion</p>
            <p><strong>Tecnologías:</strong> @Model.Tecnologias</p>
            <p><strong>Estado:</strong> @Model.Estado</p>
            <p><strong>Año de desarrollo:</strong> @Model.AnoDesarrollo</p>
            <a href="@Model.Link" target="_blank" class="btn btn-primary mb-3">Enlace Externo</a>
            <br />
            <a asp-action="Index" class="btn btn-secondary">Volver al Portfolio</a>
        </div>
    </div>
</div>