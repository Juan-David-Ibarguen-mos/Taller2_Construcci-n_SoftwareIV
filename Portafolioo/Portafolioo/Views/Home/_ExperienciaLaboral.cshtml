@model IEnumerable<WebAppPortfolio_V2.Models.ExperienciaLaboral>

<section class="container my-5">
    <h2 class="text-center mb-4">Experiencia Laboral</h2>

    @foreach (var exp in Model)
    {
        <div class="card mb-3 shadow-sm">
            <div class="card-body d-flex align-items-center">

                <!-- Icono -->
                <img src="@exp.IconoUrl" alt="Icono"
                     style="width:50px; height:50px; margin-right:15px;" />

                <div>
                    <h5 class="card-title">@exp.Cargo — @exp.Empresa</h5>

                    <h6 class="text-muted">
                        @exp.AnoInicio —
                        @(exp.AnoFin.HasValue ? exp.AnoFin.ToString() : "Actualidad")
                    </h6>

                    <p class="card-text">@exp.Descripcion</p>
                </div>

            </div>
        </div>
    }
</section>